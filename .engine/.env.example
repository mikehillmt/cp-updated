# ===========================================
# ClickCampaigns Environment Variables
# ===========================================
# Copy this file to .env and fill in your API keys
# DO NOT COMMIT .env to version control

# Google Gemini (Nano Banana Pro - AI image generation)
# Get your API key at: https://ai.google.dev/
# Used for: custom AI-generated images, branded visuals, ad creatives
GEMINI_API_KEY="your-gemini-api-key-here"

# Pexels (Stock photos for all assets)
# Get your free API key at: https://www.pexels.com/api/
# Used for: landing pages, PDFs, presentations, lead magnets
PEXELS_API_KEY="your-pexels-api-key-here"

# Firecrawl (Clone Page feature - scrape & clone any webpage)
# Get your API key at: https://www.firecrawl.dev/
# Used for: cloning existing web pages as starting points for your funnels
FIRECRAWL_API_KEY="your-firecrawl-api-key-here"

# ClickCampaigns.ai API (Auth Token mode - connect to SaaS)
# Only needed if using auth token mode to fetch campaign data from ClickCampaigns.ai
# Default: https://clickcampaigns.ai
CLICKCAMPAIGNS_API_URL="https://clickcampaigns.ai"
